#!/usr/bin/env bash
# Pre-commit hook: format staged Python files with black

# Get list of staged .py files (only added/modified, not deleted)
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$')

if [ -z "$STAGED_PY_FILES" ]; then
    exit 0
fi

# Run black on staged Python files
echo "Running black on staged Python files..."
black --config ./pyproject.toml --no-cache $STAGED_PY_FILES

if [ $? -ne 0 ]; then
    echo "black failed. Commit aborted."
    exit 1
fi

# Re-stage the formatted files
echo "$STAGED_PY_FILES" | xargs git add

exit 0
